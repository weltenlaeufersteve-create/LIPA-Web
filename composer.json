{
    "name": "pepea/lipa-web",
    "description": "NGO income/expense tracker (QuickBooks replacement)",
    "type": "project",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": ">=8.3",
        "phpoffice/phpspreadsheet": "^5.8",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": { "App\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Tests\\": "tests/" }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
